DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edenverse"
DATABASE_URL_UNPOOLED=""
AUTH_SECRET="replace-this-with-a-long-random-string"
ADMIN_SETUP_TOKEN="replace-this-with-a-one-time-random-token"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Optional: custom default hero intro before admin changes are saved.
NEXT_PUBLIC_SITE_INTRO=""

UPLOAD_DIR="public/uploads"
ENABLE_PRISMA_DEMO_FALLBACK="false"
ENABLE_DEMO_AUTH="false"

# Optional local-only demo auth. Do not set these in production.
DEMO_ADMIN_EMAIL=""
DEMO_ADMIN_PASSWORD=""
DEMO_USER_EMAIL=""
DEMO_USER_PASSWORD=""
