DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edenverse"
AUTH_SECRET="replace-this-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Optional: custom default hero intro before admin changes are saved.
NEXT_PUBLIC_SITE_INTRO=""

# Optional production CAPTCHA provider.
# If these are empty, EdenVerse uses the built-in signed math CAPTCHA for local/demo mode.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
CAPTCHA_SECRET="replace-this-with-a-long-random-string"

UPLOAD_DIR="public/uploads"
ENABLE_PRISMA_DEMO_FALLBACK="true"
